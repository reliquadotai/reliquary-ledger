# Reliquary Ledger — SN81 mainnet profile template.
# Copy to deploy/mainnet/sn81.env (gitignored) and fill in site-specific
# values. Do NOT commit filled values — the file belongs on the host only.

RELIQUARY_INFERENCE_NETWORK=finney
RELIQUARY_INFERENCE_NETUID=81
RELIQUARY_INFERENCE_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
RELIQUARY_INFERENCE_TASK_SOURCE=reasoning_tasks
RELIQUARY_INFERENCE_MODEL_REF=Qwen/Qwen3-4B-Instruct
RELIQUARY_INFERENCE_DEVICE=cuda:0
RELIQUARY_INFERENCE_LOAD_DTYPE=bfloat16
RELIQUARY_INFERENCE_MINER_MODE=single_gpu_hf
RELIQUARY_INFERENCE_SIGNATURE_SCHEME=bittensor_hotkey
RELIQUARY_INFERENCE_USE_DRAND=true
RELIQUARY_INFERENCE_STORAGE_BACKEND=r2
RELIQUARY_INFERENCE_STATE_ROOT=/var/lib/reliquary-ledger
RELIQUARY_INFERENCE_LOG_DIR=/var/log/reliquary-ledger
RELIQUARY_INFERENCE_METRICS_BIND=127.0.0.1
RELIQUARY_INFERENCE_METRICS_PORT=9108

# Wallet lifecycle — replace with your host paths; keep outside the repo.
BT_SUBTENSOR_NETWORK=finney
BT_WALLET_PATH=/home/OPERATOR/.bittensor/wallets
WALLET_NAME=reliquary-ledger
HOTKEY_NAME=validator

# Object storage credentials — use secrets manager / runtime injection,
# never commit literal keys. Pattern shown for structure only.
RELIQUARY_INFERENCE_R2_BUCKET=reliquary-ledger-artifacts
RELIQUARY_INFERENCE_R2_ENDPOINT_URL=https://ACCOUNT.r2.cloudflarestorage.com
RELIQUARY_INFERENCE_R2_ACCESS_KEY_ID=
RELIQUARY_INFERENCE_R2_SECRET_ACCESS_KEY=
RELIQUARY_INFERENCE_R2_REGION=auto

# Health endpoint wiring.
RELIQUARY_INFERENCE_HEALTH_BIND=127.0.0.1
RELIQUARY_INFERENCE_HEALTH_PORT=9180

# Flash Attention 2 required for proof-critical paths on mainnet.
RELIQUARY_INFERENCE_REQUIRE_FLASH_ATTENTION=1
