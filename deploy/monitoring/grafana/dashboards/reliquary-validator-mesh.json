{
  "uid": "reliquary-validator-mesh",
  "title": "Reliquary Validator Mesh",
  "tags": ["reliquary", "mesh", "epic5"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "",
  "time": {"from": "now-6h", "to": "now"},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Acceptance rate",
      "description": "Rolling 1h ratio of accepted completions to total completions from the mesh aggregator.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "linear", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(reliquary_mesh_completions_total{outcome=\"accepted\"}[1h])) / clamp_min(sum(rate(reliquary_mesh_completions_total[1h])), 1)",
          "legendFormat": "accepted / total",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Per-validator disagreement rate",
      "description": "Latest disagreement rate exposed by reliquary_mesh_validator_disagreement_rate, one series per validator hotkey.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.05},
              {"color": "red", "value": 0.25}
            ]
          },
          "custom": {"lineInterpolation": "stepAfter", "fillOpacity": 5}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "reliquary_mesh_validator_disagreement_rate",
          "legendFormat": "{{validator_hotkey}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Gated validators (cumulative)",
      "description": "Counter of windows in which each validator crossed MESH_OUTLIER_RATE_GATE and was dropped from median inclusion.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "stepAfter", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "reliquary_mesh_validators_gated_total",
          "legendFormat": "{{validator_hotkey}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Missing validators (cumulative)",
      "description": "Counter of windows in which each expected validator failed to submit any verdicts.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "stepAfter", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "reliquary_mesh_validators_missing_total",
          "legendFormat": "{{validator_hotkey}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last observed window",
      "description": "Most recent window_id folded into the mesh observability collector.",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "gray", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"},
      "targets": [
        {
          "refId": "A",
          "expr": "reliquary_mesh_last_window_observed",
          "legendFormat": "last_window",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}
