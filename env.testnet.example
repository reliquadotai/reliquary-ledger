# Reliquary Ledger — testnet (netuid 462) operator template.
# Copy to .env (gitignored) and fill in site-specific values.
# Quickstart: cp env.testnet.example .env && edit, then docker compose up -d miner
#
# For local-demo defaults (no chain writes), use env.example instead.
# For mainnet (netuid 81), use deploy/mainnet/sn81.env.template.

# ────────  Chain  ────────
RELIQUARY_INFERENCE_NETWORK=test
RELIQUARY_INFERENCE_NETUID=462
RELIQUARY_INFERENCE_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443
BT_SUBTENSOR_NETWORK=test

# ────────  Wallet  ────────
# Site-specific paths; keep wallet files outside the repo.
BT_WALLET_PATH=~/.bittensor/wallets
WALLET_NAME=reliquary-ledger
HOTKEY_NAME=validator
RELIQUARY_INFERENCE_VALIDATOR_SS58=
RELIQUARY_INFERENCE_MINER_SS58=

# ────────  Model + GPU  ────────
RELIQUARY_INFERENCE_MODEL_REF=Qwen/Qwen3-4B-Instruct
RELIQUARY_INFERENCE_DEVICE=cuda:0
RELIQUARY_INFERENCE_LOAD_DTYPE=bfloat16
RELIQUARY_INFERENCE_MINER_MODE=single_gpu_hf
RELIQUARY_INFERENCE_REQUIRE_FLASH_ATTENTION=1

# ────────  Task source  ────────
RELIQUARY_INFERENCE_TASK_SOURCE=math
RELIQUARY_INFERENCE_TASK_COUNT=8
RELIQUARY_INFERENCE_SAMPLES_PER_TASK=8
RELIQUARY_INFERENCE_MAX_NEW_TOKENS=512
RELIQUARY_INFERENCE_GENERATION_TEMPERATURE=0.9
RELIQUARY_INFERENCE_GENERATION_TOP_P=1.0
RELIQUARY_INFERENCE_MATH_MAX_LEVEL=2
RELIQUARY_INFERENCE_POLL_INTERVAL=15

# ────────  Signing  ────────
RELIQUARY_INFERENCE_SIGNATURE_SCHEME=bittensor_hotkey
RELIQUARY_INFERENCE_USE_DRAND=true
# Set RELIQUARY_INFERENCE_SIGNING_SECRET only when SIGNATURE_SCHEME=local_hmac.
RELIQUARY_INFERENCE_SIGNING_SECRET=

# ────────  Storage (R2)  ────────
RELIQUARY_INFERENCE_STORAGE_BACKEND=r2
RELIQUARY_INFERENCE_R2_BUCKET=reliquary-ledger-testnet
RELIQUARY_INFERENCE_R2_ENDPOINT_URL=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
RELIQUARY_INFERENCE_R2_ACCESS_KEY_ID=
RELIQUARY_INFERENCE_R2_SECRET_ACCESS_KEY=
RELIQUARY_INFERENCE_R2_ACCOUNT_ID=
RELIQUARY_INFERENCE_R2_CF_API_TOKEN=
RELIQUARY_INFERENCE_R2_PUBLIC_URL=

# ────────  State + logs  ────────
RELIQUARY_INFERENCE_STATE_ROOT=./data
RELIQUARY_INFERENCE_ARTIFACT_DIR=./data/artifacts
RELIQUARY_INFERENCE_EXPORT_DIR=./data/exports
RELIQUARY_INFERENCE_LOG_DIR=./data/logs

# ────────  Health + metrics  ────────
RELIQUARY_INFERENCE_METRICS_BIND=127.0.0.1
RELIQUARY_INFERENCE_METRICS_PORT=9108
RELIQUARY_INFERENCE_HEALTH_BIND=127.0.0.1
RELIQUARY_INFERENCE_HEALTH_PORT=9180

# ────────  Public audit (optional)  ────────
RELIQUARY_INFERENCE_AUDIT_BUCKET=
RELIQUARY_INFERENCE_AUDIT_ENDPOINT_URL=
RELIQUARY_INFERENCE_AUDIT_ACCESS_KEY_ID=
RELIQUARY_INFERENCE_AUDIT_SECRET_ACCESS_KEY=
RELIQUARY_INFERENCE_PUBLIC_AUDIT_BASE_URL=
RELIQUARY_INFERENCE_EXPOSE_PUBLIC_ARTIFACT_URLS=false
RELIQUARY_INFERENCE_AUDIT_PREFIX=audit
