RELIQUARY_INFERENCE_STATE_ROOT=./data
RELIQUARY_INFERENCE_ARTIFACT_DIR=./data/artifacts
RELIQUARY_INFERENCE_EXPORT_DIR=./data/exports
RELIQUARY_INFERENCE_LOG_DIR=./data/logs
RELIQUARY_INFERENCE_MODEL_REF=toy://local-inference-v1
RELIQUARY_INFERENCE_TASK_SOURCE=reasoning_tasks
RELIQUARY_INFERENCE_TASK_COUNT=8
RELIQUARY_INFERENCE_POLL_INTERVAL=10
RELIQUARY_INFERENCE_SAMPLES_PER_TASK=1
RELIQUARY_INFERENCE_MAX_NEW_TOKENS=48
RELIQUARY_INFERENCE_DEVICE=cpu
RELIQUARY_INFERENCE_LOAD_DTYPE=auto
RELIQUARY_INFERENCE_MINER_MODE=single_gpu_hf
RELIQUARY_INFERENCE_VLLM_BASE_URL=
RELIQUARY_INFERENCE_MINER_ID=local-miner
RELIQUARY_INFERENCE_VALIDATOR_ID=local-validator
RELIQUARY_INFERENCE_SIGNATURE_SCHEME=local_hmac
RELIQUARY_INFERENCE_SIGNING_SECRET=local-secret
RELIQUARY_INFERENCE_STORAGE_BACKEND=local
RELIQUARY_INFERENCE_NETWORK=local
RELIQUARY_INFERENCE_CHAIN_ENDPOINT=
RELIQUARY_INFERENCE_PUBLIC_AUDIT_BASE_URL=
RELIQUARY_INFERENCE_EXPOSE_PUBLIC_ARTIFACT_URLS=false
RELIQUARY_INFERENCE_AUDIT_PREFIX=audit
RELIQUARY_INFERENCE_NETUID=1
RELIQUARY_INFERENCE_USE_DRAND=false
BT_SUBTENSOR_NETWORK=test
BT_WALLET_PATH=~/.bittensor/wallets
WALLET_NAME=reliquary-inference
HOTKEY_NAME=validator
RELIQUARY_INFERENCE_R2_BUCKET=
RELIQUARY_INFERENCE_R2_ENDPOINT_URL=
RELIQUARY_INFERENCE_R2_ACCESS_KEY_ID=
RELIQUARY_INFERENCE_R2_SECRET_ACCESS_KEY=
RELIQUARY_INFERENCE_AUDIT_BUCKET=
RELIQUARY_INFERENCE_AUDIT_ENDPOINT_URL=
RELIQUARY_INFERENCE_AUDIT_ACCESS_KEY_ID=
RELIQUARY_INFERENCE_AUDIT_SECRET_ACCESS_KEY=

# To derive private artifact bucket settings from a Cloudflare R2 API token at deploy time, use:
# bash deploy/apply-r2-profile.sh
# To keep artifacts private on-node, use:
# bash deploy/apply-local-storage-profile.sh
# Then publish audit pages to a separate public target with:
# AUDIT_BUCKET=reliquary-audit AUDIT_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com AUDIT_ACCESS_KEY_ID=... AUDIT_SECRET_ACCESS_KEY=... PUBLIC_AUDIT_BASE_URL=https://audit.example.com bash deploy/apply-audit-profile.sh
# Or derive audit credentials with a Cloudflare token:
# CF_ACCOUNT_ID=... CF_API_TOKEN=... AUDIT_BUCKET=reliquary-audit PUBLIC_AUDIT_BASE_URL=https://audit.example.com bash deploy/apply-audit-profile.sh

# To pin services to a dedicated websocket endpoint, validate and apply:
# CHAIN_ENDPOINT=wss://your-endpoint.example bash deploy/apply-chain-endpoint-profile.sh

# RTX real-model baseline:
# RELIQUARY_INFERENCE_MODEL_REF=Qwen/Qwen2.5-1.5B-Instruct
# RELIQUARY_INFERENCE_DEVICE=cuda
# RELIQUARY_INFERENCE_LOAD_DTYPE=bf16
# RELIQUARY_INFERENCE_POLL_INTERVAL=15
